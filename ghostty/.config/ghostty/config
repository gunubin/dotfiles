# theme = matrix
# theme = Alabaster
# theme = ENCOM
#theme = catppuccin-macchiato
#theme = catppuccin-mocha
theme = catppuccin-frappe.conf


#font-family = "IBM Plex Mono"
#font-family = "Gintronic"
#font-family = "Atkinson Hyperlegible Mono"

#font-family = "JetBrainsMono Nerd Font"
font-family = "Berkeley Mono Variable"
font-family = "IBM Plex Sans JP"
font-feature = +calt
font-feature = +liga
font-size = 14
font-variation = wght=400
font-variation-bold = wght=850
#bold-is-bright = true
#font-thicken = true
#adjust-cell-height = -2%

cursor-style = block
cursor-style-blink = true
#cursor-invert-fg-bg = true
cursor-color = #f0e6d3
#cursor-opacity = 0.8

mouse-scroll-multiplier = 1.0
copy-on-select = true
clipboard-trim-trailing-spaces = true

fullscreen = true
macos-non-native-fullscreen = true
macos-titlebar-style = hidden

window-padding-balance = true
window-position-x = 0
window-position-y = 0
window-save-state = always
macos-window-shadow = false

background-image = ~/Pictures/ghostty-wallpaper.jpg
background-image-opacity = 0.07
background-image-fit = cover

#background-opacity = 0.75
#background-blur-radius = 20

quick-terminal-position = "top"
quick-terminal-screen = "main"
quick-terminal-animation-duration = 0.15

macos-option-as-alt = true
# toggle_visibility は macOS で unhide が不安定なため Alfred で制御
#keybind = global:ctrl+cmd+u=toggle_visibility
keybind = ctrl+tab=text:\x13\x0E
keybind = shift+ctrl+tab=text:\x13\x10
keybind = cmd+e=text:\x13\x65
keybind = cmd+t=text:\x13\x03
keybind = cmd+w=text:\x13\x77
keybind = ctrl+t=text:\x14
keybind = cmd+s=text:\x13\x01
keybind = cmd+g=text:\x13\x67
keybind = cmd+f=text:\x13\x66
keybind = cmd+z=text:\x13\x7a
keybind = cmd+p=text:\x13\x70
keybind = cmd+enter=text:\x13\x0d
keybind = cmd+n=text:\x13\x6e

# disable default shortcuts
keybind = cmd+d=unbind
keybind = shift+cmd+d=unbind
keybind = alt+cmd+w=unbind
keybind = shift+cmd+w=unbind
keybind = alt+shift+cmd+w=unbind

# tmux window switching (ctrl+s + number)
keybind = cmd+digit_1=text:\x13\x31
keybind = cmd+digit_2=text:\x13\x32
keybind = cmd+digit_3=text:\x13\x33
keybind = cmd+digit_4=text:\x13\x34
keybind = cmd+digit_5=text:\x13\x35
keybind = cmd+digit_6=text:\x13\x36
keybind = cmd+digit_7=text:\x13\x37
keybind = cmd+digit_8=text:\x13\x38
keybind = cmd+digit_9=text:\x13\x39

custom-shader-animation = true
custom-shader = ~/.config/ghostty/shaders/mode-glow.glsl
custom-shader = ~/.config/ghostty/shaders/cursor_blaze.glsl

#custom-shader = ~/.config/ghostty/shaders/glitchy.glsl
#custom-shader = ~/.config/ghostty/shaders/bettercrt.glsl
#custom-shader = ~/.config/ghostty/shaders/water.glsl
#custom-shader = ~/.config/ghostty/shaders/bloom.glsl
