# secrets.fish - ローカル環境変数（gitignore対象）
# 使い方: cp secrets.fish.example secrets.fish して編集

# Google Cloud
set -gx GOOGLE_CLOUD_PROJECT "your-project-id"

# 他のシークレット例
# set -gx OPENAI_API_KEY "sk-xxx"
# set -gx GITHUB_TOKEN "ghp_xxx"

# MCP: Google Cloud
set -gx GOOGLE_APPLICATION_CREDENTIALS "$HOME/.config/ga4-mcp-key.json"
set -gx GOOGLE_CLOUD_PROJECT "your-project-id"

# MCP: Obsidian
set -gx OBSIDIAN_API_KEY "your-api-key"
set -gx OBSIDIAN_MCP_SERVER_PATH "$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/memo/.obsidian/plugins/mcp-tools/bin/mcp-server"

# MCP: App Store Connect
set -gx APP_STORE_CONNECT_KEY_ID "your-key-id"
set -gx APP_STORE_CONNECT_ISSUER_ID "your-issuer-id"
set -gx APP_STORE_CONNECT_P8_PATH "$HOME/path/to/AuthKey.p8"

# MCP: App Ranking
set -gx APP_RANKING_DATABASE_URL "postgresql://user:pass@host:5432/dbname"
set -gx APP_RANKING_SERVER_PATH "$HOME/works/pehebase/app-ranking/mcp-server/dist/index.js"
