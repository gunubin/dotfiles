# secrets.fish - ローカル環境変数（gitignore対象）
# 使い方: cp secrets.fish.example secrets.fish して編集

# CLI paths (MCP servers が参照)
set -gx NODE_PATH "$HOME/.local/share/nvm/v22.14.0/bin/node"
set -gx NPX_PATH "$HOME/.local/share/nvm/v22.14.0/bin/npx"
set -gx UVX_PATH "$HOME/.local/bin/uvx"

# Google Cloud
set -gx GOOGLE_CLOUD_PROJECT "your-project-id"

# MCP: Google Cloud (Analytics / Search Console)
set -gx GOOGLE_APPLICATION_CREDENTIALS "$HOME/.config/ga4-mcp-key.json"

# MCP: Obsidian
set -gx OBSIDIAN_API_KEY "your-api-key"

# MCP: DataForSEO
set -gx DATAFORSEO_LOGIN "your-login"
set -gx DATAFORSEO_PASSWORD "your-password"
set -gx DATAFORSEO_API_AUTH "your-base64-auth"

# MCP: Serper
set -gx SERPER_API_KEY "your-api-key"

# MCP: mcpet
set -gx MCPET_SERVER_PATH "$HOME/works/pehebase/mono-and.blog/.mcpet-server/build/index.js"

# MCP: Filmarks
set -gx FILMARKS_SERVER_PATH "$HOME/works/mcp-servers/filmarks/dist/index.js"
set -gx FILMARKS_USER_ID "your-filmarks-user-id"

# MCP: Kindle Library
set -gx KINDLE_LIBRARY_SERVER_PATH "$HOME/works/mcp-servers/kindle-library/dist/index.js"
set -gx KINDLE_COOKIES "your-kindle-cookies"

# MCP: TMDB
set -gx TMDB_API_KEY "your-tmdb-api-key"

# MCP: Netflix
set -gx NETFLIX_MCP_PYTHON "$HOME/works/mcp-servers/netflix-search-mcp/.venv/bin/python3"
set -gx NETFLIX_MCP_SERVER_PATH "$HOME/works/mcp-servers/netflix-search-mcp/server.py"

# MCP: Keyword Analysis
set -gx KEYWORD_ANALYSIS_SERVER_PATH "$HOME/works/mcp-servers/keyword-analysis/dist/index.js"

# MCP: App Ranking
set -gx APP_RANKING_SERVER_PATH "$HOME/works/pehebase/app-ranking/mcp-server/dist/index.js"
set -gx APP_RANKING_DATABASE_URL "postgresql://user:pass@host:5432/dbname"
