{
  "_meta": {
    "description": "キーワード分析 - DataForSEO + Serper連携",
    "tags": ["seo", "keyword", "analysis"],
    "requiredEnvVars": ["DATAFORSEO_LOGIN", "DATAFORSEO_PASSWORD", "SERPER_API_KEY", "KEYWORD_ANALYSIS_SERVER_PATH"]
  },
  "type": "stdio",
  "command": "${NODE_PATH}",
  "args": ["${KEYWORD_ANALYSIS_SERVER_PATH}"],
  "env": {
    "DATAFORSEO_LOGIN": "${DATAFORSEO_LOGIN}",
    "DATAFORSEO_PASSWORD": "${DATAFORSEO_PASSWORD}",
    "SERPER_API_KEY": "${SERPER_API_KEY}"
  }
}
